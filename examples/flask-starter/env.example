# Copy this file to `.env` (with a leading dot) in the same directory and
# fill in your real key. Or, use ~/.draftboard-secrets/draftboard-api-starter
# instead — the app checks both. Get a key at intros.draftboard.com →
# Settings → API Keys → "Generate API key". `.env` is gitignored.

DRAFTBOARD_API_KEY=db-api_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: override the background sync cadence (default: 12 hours)
# SYNC_INTERVAL_HOURS=6

# Optional: override the port the dev server binds to (default: 5050)
# PORT=5051

# Optional: tune sync politeness (defaults are conservative — Draftboard's eng
# team flagged that bursting too many parallel calls is rough on the API).
# SYNC_CONCURRENCY=2     # parallel /targets/{id}/connections fetches
# SYNC_DELAY_SEC=0.3     # delay between calls in each worker

# Optional: fully disable automatic polling (scheduled daemon AND on-page-load
# auto-trigger). Manual /sync/start still works. Useful for read-only testing
# on already-cached data.
# AUTO_SYNC_ENABLED=false
