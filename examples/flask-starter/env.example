# Copy this file to `.env` (with a leading dot) in the same directory and
# fill in your real key. Or, use ~/.draftboard-secrets/draftboard-api-starter
# instead — the app checks both. Get a key at intros.draftboard.com →
# Settings → API Keys → "Generate API key". `.env` is gitignored.

DRAFTBOARD_API_KEY=db-api_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: override the background sync cadence (default: 12 hours)
# SYNC_INTERVAL_HOURS=6

# Optional: override the port the dev server binds to (default: 5050)
# PORT=5051

# Optional: tune sync politeness (defaults are conservative — Draftboard's eng
# team flagged that bursting too many parallel calls is rough on the API).
# SYNC_CONCURRENCY=2     # parallel /targets/{id}/connections fetches
# SYNC_DELAY_SEC=0.3     # delay between calls in each worker

# Optional: fully disable automatic polling (scheduled daemon AND on-page-load
# auto-trigger). Manual /sync/start still works. Useful for read-only testing
# on already-cached data.
# AUTO_SYNC_ENABLED=false

# Optional: override the SQLite path. Default is data.db next to app.py.
# Useful for tests so a throwaway DB never overwrites real synced data.
# DRAFTBOARD_DB_PATH=/tmp/draftboard-test.db

# --- Google Workspace integration (Connect → one-time scoring sync) ---
#
# The Flask app uses ONE Draftboard-owned Google OAuth client (not per-customer).
# To run this kit yourself, you need that client_id + secret. The app loads
# them in priority order:
#
#   1. GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET env vars (set them below)
#   2. .env file in this directory (uncomment and fill in)
#   3. ~/.draftboard-secrets/google.env (uses DRAFTBOARD_STARTER_GOOGLE_CLIENT_ID
#      + DRAFTBOARD_STARTER_GOOGLE_CLIENT_SECRET, with plain GOOGLE_CLIENT_ID/
#      _SECRET as fallbacks)
#
# GOOGLE_CLIENT_ID=xxxxxxxx-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
#
# Optional: redirect URI registered in your OAuth client. Must match exactly
# what's listed in the Google Cloud console under "Authorized redirect URIs".
# GOOGLE_OAUTH_REDIRECT=http://localhost:5050/auth/google/callback
#
# Optional: how many days of Gmail + Calendar history to scan. Default 365.
# GOOGLE_HISTORY_DAYS=365
#
# Optional: caps to keep the one-time sync responsive on heavy mailboxes.
# GOOGLE_THREADS_CAP=2000
# GOOGLE_EVENTS_CAP=2500

# ---------------------------------------------------------------------------
# LinkedIn resolver keys (optional)
#
# Used by the "Resolve LinkedIn" button on the Candidates page (and the test
# tool at /settings/linkedin-resolver). All four are optional — leave any
# blank and we just skip that method. With nothing set, the candidate row
# stays usable: you paste a LinkedIn URL manually before importing.
#
# You can paste these into the in-app wizard at /settings/linkedin-resolver
# instead of setting env vars — the wizard saves them to
# ~/.draftboard-secrets/draftboard-api-starter-resolver.json.
# ---------------------------------------------------------------------------

# Apollo /people/match — fastest method. Returns the LinkedIn URL directly
# when Apollo knows the person. Free tier: get a key at apollo.io → Settings
# → Integrations → API.
# APOLLO_API_KEY=

# Google Custom Search — fallback when Apollo misses. Free for 100 lookups
# per day. Setup: programmablesearchengine.google.com (create an engine,
# enable "Search the entire web", copy the engine ID) + Google Cloud Console
# (enable Custom Search API, create an API key).
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=

# OpenAI — used by the Google CSE path to rank the top results with
# gpt-4o-mini. Cost ~$0.0001 per lookup. Get a key at
# platform.openai.com/api-keys.
# OPENAI_API_KEY=
